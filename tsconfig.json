{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    

    "module": "commonjs",
    "target": "es2019",

    "lib": ["es2019"],
    "types": ["node", "jest"],
    

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true
  }
}